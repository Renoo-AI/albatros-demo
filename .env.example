# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT Secret (Required!)
# Used to sign admin authentication tokens. Set a strong random value.
# If not set, the server generates a random one at startup (invalidates all sessions on restart).
JWT_SECRET="change-me-to-a-long-random-string"

# Supabase Keys
# Set these to connect your app to your Supabase project.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_JWKS_URL="https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json"

# Stripe Publishable Key (Client-side)
# Used to initialize Stripe.js on the frontend.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Secret Key (Server-side)
# Used to create Stripe Checkout Sessions securely. Keep hidden!
STRIPE_SECRET_KEY="sk_test_..."

# Admin Password
# Used to secure the admin dashboard (/api/admin/* endpoints)
ADMIN_PASSWORD="votre_mot_de_passe_secret"

# Stripe Webhook Secret (Server-side)
# Used to verify Stripe signature on incoming payments. Keep hidden!
STRIPE_WEBHOOK_SECRET="whsec_..."

# Flouci API Keys (Tunisian Payment Gateway)
# For payments in Tunisia. Flouci is authorized by Bank Al-Maghrib.
# Get your API keys and secret signing key from https://flouci.com/dashboard
FLUOCI_API_KEY="your_flouci_api_key"
FLUOCI_APP_ID="your_flouci_app_id"
FLUOCI_SIGNING_SECRET_KEY="your_flouci_secret_key"
